# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/*
!.expo/web/
.expo/web/cache/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# VPS connection (contains host/key path)
connect-vps.bat

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Env files (secrets)
.env
.env.*
!backend/.env.example

# Google Play service account key
google-service-account.json

# Temporary upload/cache folders (e.g. Drive upload)
.tmp.driveupload/

# EAS workaround scripts (not needed in build)
scripts/eas-build-pre-install.sh
scripts/ensure-expo-web-dir.js

# Editor/IDE and Windows reserved names (avoid "nul" etc. breaking git on Windows)
.claude/
Claude/
tmpclaude-*
android-crash-log.txt
nul
con
prn
aux

# Deploy output lives in sibling wiseplan-release/; ignore if vps-landing/app exists from older setup
vps-landing/app/

# Local build/cache artifacts (machine-specific)
.android-user-home/
.gradle/
.tmp-debug/
app.json.bak
app.json.bak2
.idea/caches/

# Local runtime output
logs/
*.log
.npm-cache/
_compare_clone/
scripts/__pycache__/
dist_upload.zip

# Explicit backend local secret file (kept out of git)
backend/.env
backend/backend.prod.env
backend/*.prod.env

# Local one-off helper files (machine-specific)
Build.APK.SOFT.bat
Build_Android.APK_Nuclear.docx
Build_android.APK._SOFT.bat
Build_android.APK.nuclear.bat
Gihub_Push.bat
Performance optmization proposal and DB _ CLAUDE.rtf
VPS_Connect.bat
VPS_Deploy_Web.bat
VPS_Pull & Deploy.bat
VPS_Pull.bat
run_Claude.bat
