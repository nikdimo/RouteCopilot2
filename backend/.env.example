PORT=4000
API_BASE_PATH=/api
CORS_ALLOWED_ORIGINS=https://wiseplan.dk,https://www.wiseplan.dk,https://admin.wiseplan.dk,http://localhost:8081,http://127.0.0.1:8081,http://localhost:8088,http://127.0.0.1:8088,http://localhost:8090,http://127.0.0.1:8090
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_BILLING_MAX=120
RATE_LIMIT_WEBHOOK_MAX=300

# postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wiseplan

# auth modes:
# - azure: verify Microsoft Entra JWTs
# - dev: local bypass mode for backend development
# - magic: verify WisePlan magic-link JWTs
AUTH_MODE=dev
DEV_AUTH_AAD_OID=dev-local-user
DEV_AUTH_TENANT_ID=dev-local-tenant

# required when AUTH_MODE=azure
AZURE_TENANT_ID=
AZURE_AUDIENCE=
AZURE_ISSUER=
AZURE_JWKS_URI=

# required when AUTH_MODE=magic
MAGIC_LINK_JWT_SECRET=
MAGIC_LINK_TOKEN_ISSUER=wiseplan-auth
MAGIC_LINK_TOKEN_AUDIENCE=wiseplan-app
# Session token lifetime in minutes (recommended production: 10080 = 7 days).
MAGIC_LINK_TOKEN_TTL_MINUTES=10080
MAGIC_LINK_WEB_URL=https://wiseplan.dk/app/
MAGIC_LINK_FROM_NAME=WisePlan
MAGIC_LINK_FROM_EMAIL=hello@wiseplan.dk
MAGIC_LINK_REPLY_TO=hello@wiseplan.dk
MAGIC_LINK_SMTP_HOST=
MAGIC_LINK_SMTP_PORT=465
MAGIC_LINK_SMTP_SECURE=true
MAGIC_LINK_SMTP_USER=hello@wiseplan.dk
MAGIC_LINK_SMTP_PASS=

# cache ttl controls
GEOCODE_CACHE_TTL_DAYS=90
ROUTE_CACHE_TTL_DAYS=30

# third-party provider overrides
GEOCODE_USER_AGENT=WisePlanBackend/1.0 (admin@wiseplan.dk)
OSRM_BASE_URL=https://router.project-osrm.org
GOOGLE_MAPS_API_KEY=
# legacy alias; set GOOGLE_MAPS_API_KEY instead
GOOGLE_GEOCODING_API_KEY=
TRAFFIC_PROVIDER=osrm
BILLING_UPGRADE_URL=https://www.wiseplan.dk/billing

# billing
# BILLING_PROVIDER:
# - mock: local/dev billing without external Stripe calls
# - stripe: real Stripe checkout/portal/webhook flow
BILLING_PROVIDER=mock
BILLING_DEFAULT_CURRENCY=usd
BILLING_FRONTEND_BASE_URL=https://www.wiseplan.dk
BILLING_SUCCESS_PATH=/billing/success
BILLING_CANCEL_PATH=/billing/cancel
BILLING_PORTAL_RETURN_PATH=/account/billing
STRIPE_API_BASE_URL=https://api.stripe.com/v1
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
