# WisePlan production backend env template
# Copy this file outside git, for example:
#   C:\Secrets\wiseplan\backend.prod.env
# Then keep the real file private and never commit it.
#
# Billing is intentionally set to mock for now.
# Domain layout:
#   web:   wiseplan.dk / www.wiseplan.dk
#   api:   api.wiseplan.dk
#   admin: admin.wiseplan.dk

PORT=4000
API_BASE_PATH=/api
CORS_ALLOWED_ORIGINS=https://wiseplan.dk,https://www.wiseplan.dk,https://admin.wiseplan.dk
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_BILLING_MAX=120
RATE_LIMIT_WEBHOOK_MAX=300

# Production Postgres (prefer managed DB with SSL)
# Example: postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=postgres://REPLACE_USER:REPLACE_PASSWORD@REPLACE_HOST:5432/REPLACE_DB?sslmode=require

# auth modes:
# - magic (recommended for current launch)
# - azure
# - dev (do not use in production)
AUTH_MODE=magic
DEV_AUTH_AAD_OID=dev-local-user
DEV_AUTH_TENANT_ID=dev-local-tenant

# Required when AUTH_MODE=azure
AZURE_TENANT_ID=
AZURE_AUDIENCE=
AZURE_ISSUER=
AZURE_JWKS_URI=

# Required when AUTH_MODE=magic
# Generate a long random value (64+ chars). Example:
#   openssl rand -base64 64
MAGIC_LINK_JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
MAGIC_LINK_TOKEN_ISSUER=wiseplan-auth
MAGIC_LINK_TOKEN_AUDIENCE=wiseplan-app
# Session token lifetime in minutes (recommended: 10080 = 7 days).
MAGIC_LINK_TOKEN_TTL_MINUTES=10080
MAGIC_LINK_WEB_URL=https://wiseplan.dk/app/
MAGIC_LINK_FROM_NAME=WisePlan
MAGIC_LINK_FROM_EMAIL=hello@wiseplan.dk
MAGIC_LINK_REPLY_TO=hello@wiseplan.dk
MAGIC_LINK_SMTP_HOST=REPLACE_SMTP_HOST
MAGIC_LINK_SMTP_PORT=465
MAGIC_LINK_SMTP_SECURE=true
MAGIC_LINK_SMTP_USER=hello@wiseplan.dk
MAGIC_LINK_SMTP_PASS=REPLACE_SMTP_PASSWORD

# cache ttl controls
GEOCODE_CACHE_TTL_DAYS=90
ROUTE_CACHE_TTL_DAYS=30

# providers
GEOCODE_USER_AGENT=WisePlanBackend/1.0 (admin@wiseplan.dk)
OSRM_BASE_URL=https://router.project-osrm.org
GOOGLE_MAPS_API_KEY=
# legacy alias; set GOOGLE_MAPS_API_KEY instead
GOOGLE_GEOCODING_API_KEY=
TRAFFIC_PROVIDER=osrm
BILLING_UPGRADE_URL=https://wiseplan.dk/billing

# billing (LemonSqueezy/Stripe not enabled yet)
BILLING_PROVIDER=mock
BILLING_DEFAULT_CURRENCY=usd
BILLING_FRONTEND_BASE_URL=https://wiseplan.dk
BILLING_SUCCESS_PATH=/billing/success
BILLING_CANCEL_PATH=/billing/cancel
BILLING_PORTAL_RETURN_PATH=/account/billing
STRIPE_API_BASE_URL=https://api.stripe.com/v1
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
